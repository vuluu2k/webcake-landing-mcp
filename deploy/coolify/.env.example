# Optional server-wide config for the webcake-landing MCP (remote mode).
# Copy the values you need into Coolify's "Environment Variables" UI.
# DO NOT commit real secrets — this repo is public.
#
# This server is multi-user: clients normally send their OWN Webcake JWT per request
# (x-webcake-jwt header / Authorization: Bearer / ?jwt= query). Set values below only
# for a single-tenant server, or to give clients default base URLs.

# Port the HTTP server listens on (matches docker-compose `expose`).
PORT=8787

# Target environment — picks the API + app base URLs by name. One of: local | staging | prod
#   local   → api http://localhost:5800           app http://localhost:5173
#   staging → api https://api.staging.webcake.io  app https://staging.webcake.io
#   prod    → api https://api.webcake.io           app https://webcake.io
# Clients can also override it per request via the x-webcake-env header / ?env= query.
WEBCAKE_ENV=prod

# --- Explicit overrides (only needed to override the WEBCAKE_ENV preset) ----------
# Backend base URL — overrides the WEBCAKE_ENV preset's API base.
# WEBCAKE_API_BASE=

# Base for editor/preview URLs in results — overrides the WEBCAKE_ENV preset's app base.
# WEBCAKE_APP_BASE=

# Default organization id for create_page.
# WEBCAKE_ORG_ID=

# Shared account JWT — SINGLE-TENANT ONLY. Leave unset for a multi-user server.
# WEBCAKE_JWT=
