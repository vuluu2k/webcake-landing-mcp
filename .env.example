# Copy to `.env` and fill in. Loaded at startup by src/env.ts.
# Real environment variables and per-request HTTP headers always win over this file.

# --- search_images (Pexels stock photos) ---
# Optional: with a key, search_images calls Pexels directly; without one it falls
# back to the shared proxy below, so images still work with zero setup.
# Free key at https://www.pexels.com/api/
PEXELS_API_KEY=
# Shared hosted proxy used when no key is set (default https://mcp.toolvn.io.vn).
# PEXELS_PROXY_BASE=https://mcp.toolvn.io.vn

# --- Webcake persistence (create_page / update_page / list_*) ---
# WEBCAKE_API_BASE=http://localhost:5800
# WEBCAKE_JWT=
# WEBCAKE_ORG_ID=
# WEBCAKE_ENV=prod        # local | staging | prod — fills in the base URLs

# --- Remote serve mode / OAuth 2.1 (only for `serve` / the hosted connector) ---
# OAuth enforcement is ON by default: an unauthenticated /mcp request gets 401 +
# WWW-Authenticate so Claude/ChatGPT start the login flow. Set to 0 to allow
# anonymous Level-A access (?jwt= / x-webcake-jwt still work either way).
# WEBCAKE_OAUTH=1
# Shown on /privacy + /terms and in contact lines.
# WEBCAKE_SUPPORT_EMAIL=vuluu040320@gmail.com
# OAuth token lifetimes (ms) — defaults 1h / 30d.
# WEBCAKE_OAUTH_ACCESS_TTL_MS=
# WEBCAKE_OAUTH_REFRESH_TTL_MS=
# (builderx_spa side) trusted https hosts /mcp-connect may return the token to:
# VITE_MCP_ALLOWED_HOSTS=mcp.toolvn.io.vn
